{
  "name": "hui",
  "description": "Concise communication mode for Claude Code. Keeps technical terms, code, and safety guidance intact while reducing conversational filler.",
  "author": {
    "name": "HUI Contributors",
    "url": "https://github.com/HUI"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/src/hooks/hui-activate.js\"",
            "timeout": 5,
            "statusMessage": "Loading hui mode..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/src/hooks/hui-mode-tracker.js\"",
            "timeout": 5,
            "statusMessage": "Tracking hui mode..."
          }
        ]
      }
    ]
  }
}
